# ============================================================
# m-agents 环境变量配置模板
# 复制此文件为 .env 并修改对应的值
# cp .env.example .env
# ============================================================

# ── MySQL 数据库 ──
MYSQL_ROOT_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=m_agents
MYSQL_PORT=3306

# ── LLM 配置 ──
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus
USE_LLM=true

# ── JWT 认证 ──
JWT_SECRET_KEY=your_jwt_secret_key_here_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG_AUTH=true

# ── 日志配置 ──
LOG_FILE_ENABLED=true
LOG_ROTATION_SIZE=50 MB
LOG_RETENTION_SIZE=1 GB
LOG_COMPRESSION=gz
LOG_LEVEL=INFO

# ── 向量存储（RAG） ──
VECTOR_STORE_DIR=
EMBEDDING_MODEL=text-embedding-v4

# ── 服务端口 ──
NGINX_PORT=80
GRAFANA_PORT=3100

# ── Grafana 管理员 ──
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
